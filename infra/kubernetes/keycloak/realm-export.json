{
  "realm": "collector-realm",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": false,
  "rememberMe": true,
  "verifyEmail": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "passwordPolicy": "upperCase(1) and lowerCase(1) and digits(1) and specialChars(1) and length(12) and notUsername(true)",
  "roles": {
    "realm": [
      { "name": "user", "description": "Utilisateur standard C2C" },
      { "name": "admin", "description": "Administrateur de la marketplace" }
    ]
  },
  "clients": [
    {
      "clientId": "collector-frontend",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*", 
        "http://localhost:3000/*",
        "http://localhost/*"         
      ],
      "webOrigins": [
        "http://localhost:5173", 
        "http://localhost:3000",
        "http://localhost"
      ]
    },
    {
      "clientId": "collector-backend",
      "enabled": true,
      "bearerOnly": true
    }
  ],
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "Password123!", "temporary": false }],
      "realmRoles": ["user"]
    }
  ]
}